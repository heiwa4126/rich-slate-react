{
	"name": "rich-slate-react",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"format": "biome format --write . && dprint fmt",
		"check": "biome check --write . && dprint check",
		"trivy:check": "trivy fs . && trivy config .",
		"trivy:license": "trivy fs --scanners license --severity HIGH,CRITICAL .",
		"license": "license-checker --csv | awk -F, 'BEGIN {OFS=\",\"} {temp=$2; $2=$3; $3=temp; print}' > tmp-license.csv"
	},
	"dependencies": {
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-router-dom": "^7.4.0",
		"slate": "^0.110.2",
		"slate-history": "^0.109.0",
		"slate-react": "^0.110.3"
	},
	"devDependencies": {
		"@jridgewell/sourcemap-codec": "^1.5.0",
		"@types/node": "^22.13.13",
		"@types/react": "^18.3.20",
		"@types/react-dom": "^18.3.5",
		"@types/react-router-dom": "^5.3.3",
		"@vitejs/plugin-react-swc": "^3.8.1",
		"autoprefixer": "^10.4.21",
		"postcss": "^8.5.3",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.8.2",
		"vite": "^6.2.3",
		"vite-plugin-cdn-import": "^1.0.1"
	},
	"packageManager": "pnpm@9.12.0+sha512.4abf725084d7bcbafbd728bfc7bee61f2f791f977fd87542b3579dcb23504d170d46337945e4c66485cd12d588a0c0e570ed9c477e7ccdd8507cf05f3f92eaca"
}
